#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_NAME_LEN 50
#define MAX_DEST_LEN 50

// Define a structure for the queue node
typedef struct Node {
    char name[MAX_NAME_LEN];
    int age;
    char destination[MAX_DEST_LEN];
    int ticketID;
    struct Node* next;
} Node;

// Define a structure for the queue
typedef struct Queue {
    Node* front;
    Node* rear;
} Queue;

// Function to create a new node
Node* createNode(char* name, int age, char* destination, int ticketID) {
    Node* newNode = (Node*)malloc(sizeof(Node));
    strcpy(newNode->name, name);
    newNode->age = age;
    strcpy(newNode->destination, destination);
    newNode->ticketID = ticketID;
    newNode->next = NULL;
    return newNode;
}

// Function to create an empty queue
Queue* createQueue() {
    Queue* q = (Queue*)malloc(sizeof(Queue));
    q->front = q->rear = NULL;
    return q;
}

// Function to check if the queue is empty
int isEmpty(Queue* q) {
    return q->front == NULL;
}

// Function to add a reservation to the queue
void addReservation(Queue* q, char* name, int age, char* destination, int ticketID) {
    Node* newNode = createNode(name, age, destination, ticketID);
    if (isEmpty(q)) {
        q->front = q->rear = newNode;
    } else {
        q->rear->next = newNode;
        q->rear = newNode;
    }
    printf("Ticket reserved successfully for %s (Age: %d) to %s with ticket ID %d.\n", name, age, destination, ticketID);
}

// Function to cancel a reservation from the queue based on ticket ID
void cancelReservation(Queue* q, int ticketID) {
    if (isEmpty(q)) {
        printf("No reservations in the queue.\n");
        return;
    }

    Node *temp = q->front, *prev = NULL;

    // If the reservation to be canceled is the first in the queue
    if (temp != NULL && temp->ticketID == ticketID) {
        q->front = temp->next;
        if (q->front == NULL) {
            q->rear = NULL;
        }
        free(temp);
        printf("Reservation with ticket ID %d has been canceled.\n", ticketID);
        return;
    }

    // Search for the reservation in the queue
    while (temp != NULL && temp->ticketID != ticketID) {
        prev = temp;
        temp = temp->next;
    }

    // If the reservation was not found
    if (temp == NULL) {
        printf("No reservation found with ticket ID %d.\n", ticketID);
        return;
    }

    // Remove the node from the queue
    prev->next = temp->next;
    if (temp == q->rear) {
        q->rear = prev;
    }
    free(temp);
    printf("Reservation with ticket ID %d has been canceled.\n", ticketID);
}

// Function to display all reservations in the queue
void displayReservations(Queue* q) {
    if (isEmpty(q)) {
        printf("No reservations in the queue.\n");
        return;
    }

    Node* temp = q->front;
    printf("Current reservations:\n");
    while (temp != NULL) {
        printf("Name: %s, Age: %d, Destination: %s, Ticket ID: %d\n", temp->name, temp->age, temp->destination, temp->ticketID);
        temp = temp->next;
    }
}

// Main function to demonstrate the ticket reservation system
int main() {
    Queue* q = createQueue();
    int choice, ticketID = 1, cancelTicket;
    char name[MAX_NAME_LEN], destination[MAX_DEST_LEN];
    int age;

    while (1) {
        printf("\n--- Ticket Reservation System ---\n");
        printf("1. Add Reservation\n");
        printf("2. Cancel Reservation\n");
        printf("3. Display All Reservations\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter your name: ");
                scanf("%s", name);
                printf("Enter your age: ");
                scanf("%d", &age);
                printf("Enter your destination: ");
                scanf("%s", destination);
                addReservation(q, name, age, destination, ticketID++);
                break;
            case 2:
                printf("Enter the ticket ID to cancel: ");
                scanf("%d", &cancelTicket);
                cancelReservation(q, cancelTicket);
                break;
            case 3:
                displayReservations(q);
                break;
            case 4:
                printf("Exiting...\n");
                exit(0);
            default:
                printf("Invalid choice! Please try again.\n");
        }
    }

    return 0;
}
